{
  "name": "@datocms/cma-schema-types-generator",
  "version": "5.4.13",
  "description": "Generate TypeScript type definitions from a DatoCMS project schema",
  "keywords": [
    "datocms",
    "schema",
    "typescript",
    "codegen"
  ],
  "author": "Stefano Verna <s.verna@datocms.com>",
  "homepage": "https://github.com/datocms/js-rest-api-clients/tree/main/packages/cma-schema-types-generator#readme",
  "license": "MIT",
  "main": "dist/cjs/index.js",
  "module": "dist/esm/index.js",
  "typings": "dist/types/index.d.ts",
  "sideEffects": false,
  "directories": {
    "lib": "dist",
    "test": "__tests__"
  },
  "files": [
    "dist",
    "src"
  ],
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/datocms/js-rest-api-clients.git"
  },
  "scripts": {
    "build": "tsc && tsc --project ./tsconfig.esm.json && echo '{\"type\":\"module\"}' > dist/esm/package.json",
    "prebuild": "rimraf dist"
  },
  "bugs": {
    "url": "https://github.com/datocms/js-rest-api-clients/issues"
  },
  "peerDependencies": {
    "@datocms/cma-client": "^5.4.9"
  },
  "dependencies": {
    "@prettier/sync": "^0.6.1",
    "prettier": "^3.4.2",
    "typescript": "5.7.2"
  },
  "devDependencies": {
    "@datocms/cma-client": "^5.4.13"
  }
}
